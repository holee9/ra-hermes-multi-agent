# RA Hermes Multi-Agent — Environment Variables Template
# Copy to /opt/hermes-ra/.env and fill in actual values.
# DO NOT commit actual values to version control.

# ── Honcho / PostgreSQL / Redis ────────────────────────────────────────────────
HONCHO_SERVER_URL=http://localhost:8000
POSTGRES_URL=postgresql://honcho:honcho@localhost:5433/honcho

# ── LLM / Inference ────────────────────────────────────────────────────────────
# GX10 Ollama (OpenAI-compatible, Qwen3)
OLLAMA_URL=http://192.168.100.1:11434
GX10_URL=http://192.168.100.1:11434

# Z.ai / GLM-5.2 (OpenAI-compatible)
# General API: https://api.z.ai/api/paas/v4
# GLM Coding Plan: https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=
GLM_MODEL=glm-5.2
GLM_BASE_URL=https://api.z.ai/api/paas/v4

# ── hermes-api-server.py (Layer 4 regulatory APIs) ────────────────────────────
API_SERVER_PORT=8643
API_SERVER_KEY=

# ── Regulatory Agency APIs ─────────────────────────────────────────────────────
# openFDA (US): https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# 국가법령정보 open API (KR): https://www.law.go.kr/LSO/openAPI/openAPIMain.do
LAW_GO_KR_OC=

# 공공데이터포털 (KR): https://www.data.go.kr
DATA_GO_KR_API_KEY=

# ── External Services ──────────────────────────────────────────────────────────
OPENPROJECT_BASE_URL=https://plm.abyz-lab.work
OPENPROJECT_API_TOKEN=

N8N_URL=https://n8n.abyz-lab.work

# ── NAS (locally NFS-mounted on T3610) ────────────────────────────────────────
# Verify mount: ls /mnt/nas-ra/공통자료/RA
NAS_RA_PATH=/mnt/nas-ra/공통자료/RA

# ── Version Control ────────────────────────────────────────────────────────────
# GitHub: ra-project, MD-process API access (index_github_repos.py reads GITHUB_PAT first)
GITHUB_PAT=
GITEA_URL=http://diskstation:7001
GITEA_TOKEN=
GITEA_WIKI_REPO=DR_RnD/ra-llm-wiki

# ── Layer 4 knowledge fetch ────────────────────────────────────────────────────
# Per-source timeout for knowledge_fetch.py (seconds)
LAYER4_TIMEOUT=8

# ── Misc ───────────────────────────────────────────────────────────────────────
HERMES_RA_DIR=/opt/hermes-ra

# Legacy (Qdrant → pgvector migration completed in #17 — keep for reference only)
# QDRANT_URL=http://localhost:6333
