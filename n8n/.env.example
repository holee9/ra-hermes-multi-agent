# n8n 워크플로우 공통 환경변수
# 라즈베리파이 n8n 인스턴스의 .env 또는 n8n 설정에 등록

# Hermes API (RA 에이전트 호출)
HERMES_API_URL=http://localhost:5000

# Honcho API (기록 연동) — n8n Global Variables에 등록 필요
# RPi에서 T3610 Honcho 접근: http://10.20.6.140:8000
HONCHO_API_URL=http://10.20.6.140:8000
# 워크플로우에서 $env.HONCHO_WORK_WORKSPACE 로 참조 (HONCHO_APP_NAME 아님)
HONCHO_WORK_WORKSPACE=ra-hermes

# OpenProject (WP 연동)
OPENPROJECT_API_URL=http://localhost:8080
OPENPROJECT_API_KEY=your-openproject-api-key
OPENPROJECT_DEFAULT_PROJECT_ID=1

# 알림 이메일 (Yellow 게이트, Honcho 장애 경보)
HUMAN_ALERT_EMAIL=ops@yourcompany.com
# 선택: Yellow 게이트 payload를 받을 n8n/Slack/OP relay webhook
HUMAN_ALERT_WEBHOOK_URL=

# [IF] 브릿지 전달 조건 JSON. 비워두면 초기 기본값(모두 전달)을 유지.
# 예: {"relay_threshold":0.67,"relay_conditions":[{"result":"approved","min_approve_ratio":0.67}]}
BRIDGE_RELAY_CONFIG_JSON=

# [IF] 피드백 가중치 조정 JSON. 비워두면 기록만 하고 가중치 조정은 하지 않음.
WEIGHT_ADJUSTMENT_CONFIG_JSON=

# 게이트 임계값 (하드코딩 금지 — 여기서 읽음)
# confidence < 이 값 → Yellow 게이트 (사람 검토 권장)
YELLOW_CONFIDENCE_THRESHOLD=0.70
