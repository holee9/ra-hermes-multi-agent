# n8n 워크플로우 공통 환경변수
# 라즈베리파이 n8n 인스턴스의 .env 또는 n8n 설정에 등록

# Hermes API (RA 에이전트 호출)
HERMES_API_URL=http://localhost:5000

# Honcho API (기록 연동)
HONCHO_API_URL=http://192.168.x.x:8000
HONCHO_APP_NAME=ra-hermes

# OpenProject (WP 연동)
OPENPROJECT_API_URL=http://localhost:8080
OPENPROJECT_API_KEY=your-openproject-api-key
OPENPROJECT_DEFAULT_PROJECT_ID=1

# 알림 이메일 (Yellow 게이트, Honcho 장애 경보)
HUMAN_ALERT_EMAIL=ops@yourcompany.com

# 게이트 임계값 (하드코딩 금지 — 여기서 읽음)
# confidence < 이 값 → Yellow 게이트 (사람 검토 권장)
YELLOW_CONFIDENCE_THRESHOLD=0.70
