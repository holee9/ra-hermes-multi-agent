      {
        "parameters": {
          "jsCode": "// RA 분석 결과 JSON 파싱 및 검증\n// 고정 계약: { actor, wp, match, confidence, region, comment, transition_proposed }\nconst raw = $input.item.json;\nlet analysis;\ntry {\n  const content = raw.choices?.[0]?.message?.content || raw.content || '{}';\n  // JSON 블록 추출 (모델이 마크다운으로 감쌀 수 있음)\n  const jsonMatch = content.match(/```json\\s*([\\s\\S]+?)\\s*```/) || content.match(/({[\\s\\S]+})/);\n  analysis = JSON.parse(jsonMatch ? jsonMatch[1] : content);\n} catch (e) {\n  return [{ json: { parse_error: true, raw_content: raw.choices?.[0]?.message?.content || '', error: e.message } }];\n}\n\n// 필수 필드 검증\nconst required = ['actor', 'match', 'confidence', 'region', 'comment'];\nconst missing = required.filter(f => analysis[f] === undefined);\nif (missing.length > 0) {\n  return [{ json: { parse_error: true, missing_fields: missing, analysis } }];\n}\n\nreturn [{ json: { ...analysis, parse_error: false } }];"
        },
