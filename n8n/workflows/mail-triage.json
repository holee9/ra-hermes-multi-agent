                "name": "=",
                "value": "={{ JSON.stringify({\n  model: $json.primary_actor,\n  messages: [{\n    role: 'user',\n    content: [\n      'You are processing a forwarded regulatory affairs email.',\n      'Original subject: ' + $json.original_subject,\n      'Original from: ' + $json.original_from,\n      'Matching key: ' + $json.matching_key,\n      'Body excerpt: ' + $json.body_excerpt,\n      '',\n      'Analyze this case and return ONLY a JSON object with these fields:',\n      '{ \"actor\": \"' + $json.primary_actor + '\", \"wp\": \"WP-XXX or null\", \"match\": \"existing or new\", \"confidence\": 0.0-1.0, \"region\": \"' + $json.primary_region + '\", \"comment\": \"...\", \"transition_proposed\": \"status or null\" }',\n      '',\n      'For wp: use the WP reference if found in the email, or search your memory for matching cases.',\n      'For match: \"existing\" if this is a follow-up to a known case, \"new\" if this is a new matter.',\n      'For transition_proposed: only propose if the email content clearly signals a status change, otherwise null.',\n      'Return ONLY the JSON object, no other text.'\n    ].join('\\n')\n  }]\n}) }}"
