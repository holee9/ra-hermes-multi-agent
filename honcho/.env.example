# PostgreSQL
POSTGRES_USER=honcho
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=honcho

# GX10 Qwen3 LLM 위임 — 4개 섹션 모두 동일 엔드포인트
# Qwen3는 tool-calling 지원 필수 (deriver 관찰 추출에 사용)
GX10_BASE_URL=http://GX10_실제IP:11434/v1
# GX10 실제 실행 모델: kqwen-coder:latest (qwen3:30b 아님)
# ⚠️ tool-calling 지원 여부 확인 필수: ollama show kqwen-coder:latest | grep -i tool
GX10_MODEL=kqwen-coder:latest

# LLM 모델 설정 패턴:
#   __MODEL = ConfiguredModelSettings.model (모델명 직접 설정)
#   __OVERRIDES__BASE_URL = 커스텀 엔드포인트
#   __OVERRIDES__API_KEY = API 키 (Ollama는 "ollama" 플레이스홀더 사용)
# 주의: __OVERRIDES__MODEL은 ModelOverrideSettings에 model 필드 없음 → 무시됨
DERIVER_MODEL_CONFIG__MODEL=${GX10_MODEL}
DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DERIVER_MODEL_CONFIG__OVERRIDES__API_KEY=ollama
DIALECTIC_MODEL_CONFIG__MODEL=${GX10_MODEL}
DIALECTIC_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DIALECTIC_MODEL_CONFIG__OVERRIDES__API_KEY=ollama
SUMMARY_MODEL_CONFIG__MODEL=${GX10_MODEL}
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
SUMMARY_MODEL_CONFIG__OVERRIDES__API_KEY=ollama
# Dreamer specialist (config.py 기본값 gpt-5.4-mini → GX10으로 재설정)
DREAM_DEDUCTION_MODEL_CONFIG__MODEL=${GX10_MODEL}
DREAM_DEDUCTION_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DREAM_DEDUCTION_MODEL_CONFIG__OVERRIDES__API_KEY=ollama
DREAM_INDUCTION_MODEL_CONFIG__MODEL=${GX10_MODEL}
DREAM_INDUCTION_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DREAM_INDUCTION_MODEL_CONFIG__OVERRIDES__API_KEY=ollama

# 임베딩: GX10 로컬 임베딩 사용 (4096차원)
# ⚠️ pgvector 스키마가 기본 1536차원으로 초기화됨 → 첫 docker-compose up 전 반드시 처리
# 주의: __OVERRIDES__MODEL은 무시됨 → __MODEL로 직접 설정 (LLM 섹션과 동일 패턴)
EMBEDDING_MODEL_CONFIG__MODEL=qwen3-embedding:latest
EMBEDDING_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
EMBEDDING_MODEL_CONFIG__OVERRIDES__API_KEY=ollama

# Honcho 앱 인증
HONCHO_APP_NAME=ra-hermes
SECRET_KEY=change_me_in_production
