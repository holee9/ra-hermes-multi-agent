# PostgreSQL
POSTGRES_USER=honcho
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=honcho

# GX10 Qwen3 LLM 위임 — 4개 섹션 모두 동일 엔드포인트
# Qwen3는 tool-calling 지원 필수 (deriver 관찰 추출에 사용)
GX10_BASE_URL=http://GX10_실제IP:11434/v1
# GX10 실제 실행 모델: kqwen-coder:latest (qwen3:30b 아님)
# ⚠️ tool-calling 지원 여부 확인 필수: ollama show kqwen-coder:latest | grep -i tool
GX10_MODEL=kqwen-coder:latest

DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DERIVER_MODEL_CONFIG__OVERRIDES__MODEL=${GX10_MODEL}
DIALECTIC_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DIALECTIC_MODEL_CONFIG__OVERRIDES__MODEL=${GX10_MODEL}
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
SUMMARY_MODEL_CONFIG__OVERRIDES__MODEL=${GX10_MODEL}
DREAM_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
DREAM_MODEL_CONFIG__OVERRIDES__MODEL=${GX10_MODEL}

# 임베딩: GX10 로컬 임베딩 사용 (4096차원)
# ⚠️ pgvector 스키마가 기본 1536차원으로 초기화됨 → 첫 docker-compose up 전 반드시 처리
# 처리 방법: docker-compose.yml postgres 서비스에 init SQL 마운트 (아래 주석 참조)
# 또는 Honcho 환경변수 EMBEDDING_DIM=4096 지원 여부 확인 후 설정
EMBEDDING_MODEL_CONFIG__OVERRIDES__BASE_URL=${GX10_BASE_URL}
# GX10에서 실행 중인 임베딩 모델명으로 교체 필요 (예: qwen3-embedding, bge-m3 등)
EMBEDDING_MODEL_CONFIG__OVERRIDES__MODEL=qwen3-embedding:latest

# Honcho 앱 인증
HONCHO_APP_NAME=ra-hermes
SECRET_KEY=change_me_in_production
