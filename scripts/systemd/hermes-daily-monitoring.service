[Unit]
Description=RA Hermes Daily Monitoring
After=network.target honcho-api.service honcho-postgres.service honcho-redis.service

[Service]
Type=oneshot
User=abyz-lab
WorkingDirectory=/home/abyz-lab/work/workspace-github/holee9/ra-hermes-multi-agent
ExecStart=/home/abyz-lab/work/workspace-github/holee9/ra-hermes-multi-agent/scripts/daily-monitoring.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target